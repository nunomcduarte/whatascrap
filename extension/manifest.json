{
  "manifest_version": 3,
  "name": "WhatAScrap",
  "version": "0.1.0",
  "description": "Save YouTube transcripts to your library.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-world.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "action": {
    "default_title": "WhatAScrap",
    "default_popup": "popup.html"
  }
}
